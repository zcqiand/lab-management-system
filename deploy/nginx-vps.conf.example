# VPS nginx vhost — lab-management-system
#
# 这是参考模板，不会被 nginx 自动 include。setup-vps.sh 会把
# YOUR_DOMAIN 替换为实际域名后写入 /etc/nginx/sites-available/。
# 使用前请把证书放到 /etc/nginx/ssl/your-cert.{crt,key}。

server {
    listen 80;
    server_name YOUR_DOMAIN;
    return 301 https://$host$request_uri;
}

server {
    listen 80 default_server;
    server_name _;
    return 444;
}

server {
    listen 443 ssl http2;
    server_name YOUR_DOMAIN;

    # 证书只保留在 VPS，不提交到仓库。
    ssl_certificate     /etc/nginx/ssl/your-cert.crt;
    ssl_certificate_key /etc/nginx/ssl/your-cert.key;

    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    add_header Strict-Transport-Security "max-age=31536000" always;

    location / {
        # 与 deploy/lab-management-system.sh 的端口绑定保持一致。
        proxy_pass http://127.0.0.1:8062;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
