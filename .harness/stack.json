{
  "schema": 1,
  "suite_version": "0.5.0",
  "project": "lab-management-system",
  "stack": "react-ts",
  "gates": {
    "L1": {
      "name": "格式",
      "cmd": [
        "npx",
        "--no",
        "prettier",
        "--check",
        "src",
        "tests"
      ],
      "fix": "先确认 `npm install` 跑过。然后 `npx prettier --write src tests`。"
    },
    "L2": {
      "name": "静态检查",
      "cmd": [
        "npx",
        "--no",
        "eslint",
        "src",
        "tests"
      ],
      "fix": "逐条修复 eslint。禁止用 eslint-disable 掩盖，除非同行注释给出理由。"
    },
    "L3": {
      "name": "类型",
      "cmd": [
        "npx",
        "--no",
        "tsc",
        "--noEmit"
      ],
      "fix": "补全类型。禁止 any / @ts-ignore 绕过，除非附 ADR 说明。"
    },
    "L4": {
      "name": "测试",
      "cmd": [
        "npx",
        "--no",
        "vitest",
        "run"
      ],
      "fix": "先让测试变绿，再谈重构。若测试本身有误，改测试前必须先说明理由。"
    }
  },
  "trace_cmd": [
    "node",
    "tests/trace-parse.js"
  ],
  "source_dirs": [
    "src"
  ],
  "test_dirs": [
    "tests"
  ]
}
